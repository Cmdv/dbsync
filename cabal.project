active-repositories:
  , :rest
  , cardano-haskell-packages:override

packages:
  dbsync-db
  dbsync
  dbsync-smash

-- ---------------------------------------------------------------------------
-- Package flags
-- ---------------------------------------------------------------------------

package postgresql-libpq
  flags: +use-pkg-config

package cryptonite
  flags: -support_rdrand

package text
  flags: -simdutf

package snap-server
  flags: -openssl

package cardano-node
  flags: -systemd

-- 'blockio' wraps the system-level block I/O primitives used by the
-- LSM-tree backend. It has two implementations:
--
--   * Default (no flag): uses 'io_uring' on Linux for batched,
--     asynchronous I/O. Faster — see LEDGER-PERF.md §3.2 / §4.2 for
--     why this matters: the 'lsmRead' + 'lsmDuplicate' calls in
--     'tickThenReapplyCheckHash' are on the critical path of every
--     ledger apply, and Mary/Alonzo apply times scale with their
--     latency.
--   * '+serialblockio': falls back to a synchronous, syscall-per-op
--     implementation. Portable; the only choice on macOS / Windows /
--     other non-Linux targets where 'io_uring' is unavailable.
--
-- Linux operators need 'liburing-dev' (Ubuntu) / 'liburing-devel'
-- (Fedora) installed before building. Available on any kernel
-- ≥ 5.1, which is every distro currently in support.
--
-- macOS / other developers: nothing to do — the conditional below
-- picks the serial fallback automatically.
if !os(linux)
  package blockio
    flags: +serialblockio

-- ---------------------------------------------------------------------------
-- Constraints
-- ---------------------------------------------------------------------------

constraints:
  , text < 2.1.2

-- Allow-newer clauses needed by LSM/LedgerDB V2 transitive deps.
allow-newer:
  , cardano-api:plutus-core
  , resource-registry:nothunks

if impl (ghc >= 9.12)
  allow-newer:
    , Unique:hashable

-- ---------------------------------------------------------------------------
-- Tests
-- ---------------------------------------------------------------------------

tests: True
test-show-details: direct
write-ghc-environment-files: always

-- ---------------------------------------------------------------------------
-- Source repository packages
-- ---------------------------------------------------------------------------

source-repository-package
  type: git
  location: https://github.com/IntersectMBO/cardano-node
  tag: 045bc187a36ef0cbd236db902b85dd8f202fb059
  --sha256: sha256-D2HMIr65q0RM9+ZAjbtA9xNKyoKYfr3Kc4Vv4+s64uY=
  subdir:
    cardano-node
    trace-forward
    trace-resources
