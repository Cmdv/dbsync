index-state:
  , hackage.haskell.org 2025-09-29T13:55:56Z
  , cardano-haskell-packages 2026-03-30T15:30:34Z

active-repositories:
  , :rest
  , cardano-haskell-packages:override

packages:
  dbsync-db
  dbsync
  dbsync-smash

-- ---------------------------------------------------------------------------
-- Package flags
-- ---------------------------------------------------------------------------

package postgresql-libpq
  flags: +use-pkg-config

package cryptonite
  flags: -support_rdrand

package text
  flags: -simdutf

package snap-server
  flags: -openssl

package cardano-node
  flags: -systemd

-- ---------------------------------------------------------------------------
-- Constraints
-- ---------------------------------------------------------------------------

constraints:
  , text < 2.1.2
  -- ouroboros-network-framework requires random ^>= 1.2 (< 1.3),
  -- but hspec-core can pull in random 1.3.x. Pin to 1.2 range.
  , random < 1.3

if impl (ghc >= 9.12)
  allow-newer:
    , Unique:hashable

-- ---------------------------------------------------------------------------
-- Tests
-- ---------------------------------------------------------------------------

tests: True
test-show-details: direct
write-ghc-environment-files: always

-- ---------------------------------------------------------------------------
-- Source repository packages
-- ---------------------------------------------------------------------------

source-repository-package
  type: git
  location: https://github.com/IntersectMBO/cardano-node
  tag: 0d697f14ee10a775f08c60e3839becc9131dca75
  --sha256: sha256-zyrBw3yn69y3n0c6U0MDvezYC3GHbjJ3yJmhM4vMtUk=
  subdir:
    cardano-node
    trace-dispatcher
    trace-forward
    trace-resources
