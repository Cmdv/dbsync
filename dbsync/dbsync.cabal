-- ---------------------------------------------------------------------------
-- Executable
-- ---------------------------------------------------------------------------
executable dbsync
  import:         warnings, defaults
  hs-source-dirs: app
  main-is:        Main.hs
  -- RTS flags tuned for loader-stream encoding (many short-lived
  -- ByteStrings that should die in the nursery).
  --   -A64m  : 64 MB nursery (vs default 4 MB) — minor GC 16x less often
  --   -N6    : 6 capabilities
  --   -T     : enable GHC runtime statistics
  --
  -- We deliberately *omit* --disable-delayed-os-memory-return so that
  -- pages freed by the GC are returned to the kernel between
  -- collections. With the flag enabled, RSS pins at peak heap forever,
  -- masking dedup-map growth as a 16+ GB RSS regression. See
  -- PLANS/MEMORY_INVESTIGATION.md (Slice A).
  ghc-options:    -threaded -rtsopts "-with-rtsopts=-A64m -N6 -T"
  build-depends:
      dbsync
    , cardano-prelude
    , contra-tracer
    , filepath
