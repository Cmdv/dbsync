{
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "cexplorer",
    "user": "",
    "password": ""
  },
  "sync": {
    "mode": "auto",
    "checkpoint_dir": "/data/checkpoints",
    "copy_connections": 12
  },
  "ledger": {
    "enabled": false
  },
  "options": {
    "core":             { "enabled": true },
    "utxo":             { "enabled": true },
    "multi_asset":      { "enabled": true },
    "metadata":         { "enabled": true },
    "stake_delegation": { "enabled": true },
    "pool":             { "enabled": true },
    "scripts_datums":   { "enabled": true },
    "governance":       { "enabled": true },
    "cbor":             { "enabled": true },
    "epoch_sync_stats": { "enabled": true },
    "epoch_boundary":   { "enabled": false },
    "current_state":    { "enabled": false }
  },
  "metrics": {
    "prometheus_port": 8080
  },
  "logging": {
    "level": "info",
    "format": "text"
  }
}
