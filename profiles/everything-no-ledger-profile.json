{
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "cexplorer",
    "user": "",
    "password": ""
  },
  "sync": {
    "mode": "auto",
    "checkpoint_dir": "/data/checkpoints",
    "loader_connections": 4
  },
  "ledger": {
    "enabled": false
  },
  "db_options": {
    "utxo": {
      "enabled": true,
      "consumed_by_tx_id": true,
      "tx_in": true,
      "strategy": "archive"
    },
    "multi_asset": true,
    "metadata": true,
    "stake_delegation": true,
    "pool": true,
    "scripts_datums": true,
    "governance": true,
    "cbor": true,
    "epoch_sync_stats": true
    
  },
  "metrics": {
    "prometheus_port": 8080
  },
  "logging": {
    "level": "info",
    "format": "text"
  }
}
