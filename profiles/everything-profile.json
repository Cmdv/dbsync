{
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "cexplorerpreview",
    "user": "",
    "password": ""
  },
  "sync": {
    "mode": "auto",
    "checkpoint_dir": "/data/checkpoints",
    "loader_connections": 12
